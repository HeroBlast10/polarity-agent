# Copy this file to .env and fill in your values.
# .env is git-ignored so your secrets stay local.

# ── LLM Provider ─────────────────────────────────────────────────────────
# Supported: ollama | openai | litellm
# POLARITY_PROVIDER=ollama
# POLARITY_PROVIDER=litellm
POLARITY_PROVIDER=openai


# Model name understood by the chosen provider
# POLARITY_MODEL=nousresearch/hermes-2-pro-llama-3-8b
# POLARITY_MODEL=cognitivecomputations/dolphin-mistral-24b-venice-edition:free
POLARITY_MODEL=deepseek-chat

# Optional: custom base URL (e.g. local Ollama, Azure OpenAI endpoint)
# POLARITY_BASE_URL=http://localhost:11434
# POLARITY_BASE_URL=https://openrouter.ai/api/v1
POLARITY_BASE_URL=https://api.deepseek.com

# API key — required for openai / litellm, leave blank for local ollama
# POLARITY_API_KEY=sk-...

# ── Defaults ─────────────────────────────────────────────────────────────
# Default persona pack (advocatus | inquisitor | <custom>)
POLARITY_PACK=advocatus
# POLARITY_PACK=inquisitor
